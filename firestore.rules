rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users (Private)
    // Fields: uid, email, createdAt
    //
    // Collection: profiles (Public)
    // Fields: uid, username, displayName, photoURL, socialLinks, bio, onboarded, updatedAt
    //
    // Collection: groups
    // Fields: title, about, goal, ownerId, members (array of uids), createdAt
    //
    // Collection: feed
    // Fields: content, authorId, authorUsername, createdAt
    //
    // Collection: chatSessions
    // Fields: userId, title, createdAt
    //
    // Collection: chatSessions/{sessionId}/messages
    // Fields: sessionId, role, content, createdAt
    //
    // Collection: memories
    // Fields: userId, content, updatedAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidSocialLink(link) {
      return link is map &&
             link.platform is string && link.platform.size() > 0 && link.platform.size() <= 50 &&
             link.url is string && link.url.matches("^https?://.*");
    }

    function isValidProfile(data) {
      return hasRequiredFields(['uid', 'username']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000000)) &&
             (!('socialLinks' in data) || (data.socialLinks is list && data.socialLinks.size() <= 10)) &&
             (!('onboarded' in data) || data.onboarded is bool) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidGroup(data) {
      return hasRequiredFields(['title', 'about', 'goal', 'ownerId', 'members']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.about is string && data.about.size() <= 1000 &&
             data.goal is string && data.goal.size() <= 500 &&
             data.ownerId is string &&
             data.members is list && data.members.size() <= 100 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidFeedPost(data) {
      return hasRequiredFields(['content', 'authorId', 'authorUsername']) &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.authorId is string &&
             data.authorUsername is string && data.authorUsername.size() <= 50 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidChatSession(data) {
      return hasRequiredFields(['userId', 'title']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidChatMessage(data) {
      return hasRequiredFields(['sessionId', 'role', 'content']) &&
             data.sessionId is string &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidMemory(data) {
      return hasRequiredFields(['userId', 'content']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 10000 &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    // User Data (Private)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // User Profiles (Public)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data);
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGroup(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidGroup(request.resource.data) && 
                    (
                      // Owner can update anything
                      resource.data.ownerId == request.auth.uid || 
                      // Others can only update the members list (joining/leaving)
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                        (request.auth.uid in request.resource.data.members || !(request.auth.uid in request.resource.data.members))
                      )
                    );
    }

    // Feed
    match /feed/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFeedPost(request.resource.data);
      allow update: if false;
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidChatSession(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidChatSession(request.resource.data);

      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid && isValidChatMessage(request.resource.data);
      }
    }

    // Memories
    match /memories/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMemory(request.resource.data);
      allow update: if isOwner(userId) && isValidMemory(request.resource.data);
    }
  }
}
